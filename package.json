{
  "name": "openfilms",
  "version": "1.0.0",
  "description": "OpenFilms Application",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "vite build",
    "build:exe": "npm run build && electron-builder --dir"
  },
  "build": {
    "appId": "com.ikonadev.openfilms",
    "win": {
      "target": "dir"
    },
    "directories": {
      "output": "bild"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ikonadev/openfilms.git"
  },
  "keywords": [],
  "author": "Ikonadev",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/ikonadev/openfilms/issues"
  },
  "homepage": "https://github.com/ikonadev/openfilms#readme",
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.18.1",
    "cross-fetch": "^4.1.0",
    "jimp": "^1.6.1",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-packager": "^17.1.2",
    "vite": "^8.1.3",
    "wait-on": "^9.0.10"
  }
